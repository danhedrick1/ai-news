# Copy this file to .env and fill in your values
# Then run: export ANTHROPIC_API_KEY=sk-ant-... or source .env

ANTHROPIC_API_KEY=sk-ant-your-key-here
GITHUB_TOKEN=github_pat_your-token-here

# Beehiiv — get these from app.beehiiv.com → Settings → API
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Optional: generic webhook fallback if Beehiiv is not configured
NEWSLETTER_WEBHOOK_URL=

# REPO_PATH defaults to script directory if not set
