# Copy this file to .env and fill in your values
# Then run: export ANTHROPIC_API_KEY=sk-ant-... or source .env

ANTHROPIC_API_KEY=sk-ant-your-key-here
GITHUB_TOKEN=github_pat_your-token-here

# Kit (fka ConvertKit) — get these from app.kit.com → Settings → Developer
# KIT_API_KEY: your public API key (safe for server-side use)
# KIT_FORM_ID: the numeric ID of the form new subscribers should enter
#   (found in Kit → Forms → your form → the URL: /forms/XXXXXXX/edit)
KIT_API_KEY=
KIT_FORM_ID=

# Optional: generic webhook fallback if Kit is not configured
NEWSLETTER_WEBHOOK_URL=

# REPO_PATH defaults to script directory if not set
